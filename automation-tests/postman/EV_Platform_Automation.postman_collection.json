                  "});\r",
                  "\r",
                  "let jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Access token exists\", function () {\r",
                  "    pm.expect(jsonData.access_token).to.exist;\r",
                  "});\r",
                  "\r",
                  "if (jsonData.access_token) {\r",
                  "    pm.environment.set(\"token\", jsonData.access_token);\r",
                  "}"
